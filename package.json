{
  "name": "prismatique-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently --kill-others \"npm run dev:client\" \"npm run dev:server\"",
    "install:all": "cd client && npm install && cd ../server && npm install",
    "start:client": "cd client && npm run start",
    "start:server": "cd server && npm run start",
    "start": "concurrently --kill-others \"npm run start:client\" \"npm run start:server\""
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
