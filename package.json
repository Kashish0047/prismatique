{
  "name": "prismatique-site",
  "version": "1.0.0",
  "description": "Prismatique website with Node.js backend",
  "main": "api.js",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "start": "node api.js",
    "start:frontend": "node server.js",
    "dev": "nodemon server.js",
    "dev:api": "nodemon api.js",
    "deploy": "npm run build && gh-pages -d dist -b gh-pages",
    "deploy-simple": "gh-pages -d . -b gh-pages",
    "build": "echo 'No build step needed for static site'",
    "deploy-git": "git add . && git commit -m \"Update website\" && git push origin main"
  },
  "dependencies": {
    "express": "^4.18.2",
    "path": "^0.12.7",
    "vercel": "^51.3.0"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "prismatique",
    "website",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bablx/prismatique.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/bablx/prismatique/issues"
  },
  "homepage": "https://github.com/bablx/prismatique#readme"
}
